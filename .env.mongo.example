# --- Append these to your Laravel .env after `composer create-project` ---

# MariaDB (default Laravel DB_* connection is fine — just confirm it points here)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lattis_atlas
DB_USERNAME=root
DB_PASSWORD=

# MongoDB (via mongodb/laravel-mongodb) — article bodies, author personas, prompts
MONGO_DB_HOST=127.0.0.1
MONGO_DB_PORT=27017
MONGO_DB_DATABASE=lattis_atlas_content
MONGO_DB_USERNAME=
MONGO_DB_PASSWORD=

# Redis (Horizon queue driver)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
QUEUE_CONNECTION=redis

# AI provider — start with ONE (see MVP_ROADMAP.md Stage 0), add others behind
# AIProviderInterface later. Never hardcode a key in code — only here.
AI_PROVIDER=openai            # openai | claude | ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Publishing target for your first pilot site(s) — real per-site credentials
# belong ENCRYPTED in the `credentials` table via CredentialService, not here.
# This is only for local dev convenience if you need a quick default.
DEFAULT_STACK_TYPE=wordpress  # wordpress | ftp_html
